NEXT_PUBLIC_APP_URL="https://nature-colorpalette.web.app"

# ── Firebase Firestore (project: nature-colorpalette) ─────────────────────
# Download service account JSON from Firebase → Project settings → Service accounts
# Place the file in project root and point to it here (recommended):
FIREBASE_SERVICE_ACCOUNT_PATH="nature-colorpalette-firebase-adminsdk-fbsvc-70838260b8.json"

# Or paste credentials manually:
# FIREBASE_PROJECT_ID=nature-colorpalette
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@nature-colorpalette.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Public web config (from Firebase console → Project settings → Your apps)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="nature-colorpalette.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="nature-colorpalette"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="nature-colorpalette.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""

# Force local JSON instead of Firestore while developing:
# USE_JSON_DATA=true

# PostgreSQL (optional alternative backend)
# DATABASE_URL="postgresql://..."
