NEXT_PUBLIC_APP_URL="https://nature-colorpalette.web.app"

# ── Firebase Firestore (catalog database) ─────────────────────────────────
# Service account JSON from Firebase → Project settings → Service accounts
FIREBASE_SERVICE_ACCOUNT_PATH="nature-colorpalette-firebase-adminsdk-fbsvc-70838260b8.json"

# Or paste credentials manually:
# FIREBASE_PROJECT_ID=nature-colorpalette
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@...
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Static export uses dataset.json (set in CI). Use Firestore in dev optionally:
# USE_JSON_DATA=true

# ── Kaggle Birds 525 dataset (optional, for ingest) ───────────────────────
# Download: https://www.kaggle.com/datasets/gpiosenka/100-bird-species
# KAGGLE_DATA_DIR="/path/to/100-bird-species"
